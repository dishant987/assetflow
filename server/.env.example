# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/assetflow?sslmode=require
# JWT secrets
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
# Client origin (comma-separated in production: Vercel URL + local dev)
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
# Server
PORT=3001
NODE_ENV=development
# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass
EMAIL_FROM=noreply@assetflow.com
OTP_EXPIRY_MINUTES=10
# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
